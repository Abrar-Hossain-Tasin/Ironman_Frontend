  status: OrderStatus
  paymentMethod: 'cod' | 'online'
  paymentStatus: PaymentStatus
  totalAmount: number
  paidAmount: number
  items: OrderItemResponse[]
  createdAt: string
  updatedAt: string
}

export type OrderSummary = {
  id: string
  orderNumber: string
