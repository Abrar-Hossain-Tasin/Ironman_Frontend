}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  background: #ffffff;
  color: #374151;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font: inherit;
}

@layer components {
  .container-page {
    @apply mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8;
  }

  .tap-target {
    @apply min-h-11 min-w-11;
  }

  .focus-ring {
    @apply focus:outline-none focus:ring-2 focus:ring-ironman-red focus:ring-offset-2;
  }
}
